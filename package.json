{
  "name": "reststop",
  "version": "1.0.11",
  "private": true,
  "license": "Apache-2.0",
  "description": "Simple restic backups.",
  "main": "electron/main.cjs",
  "scripts": {
    "icons": "node scripts/generate-app-icons.cjs",
    "predev": "node scripts/generate-app-icons.cjs",
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 node scripts/start-electron.cjs .\"",
    "prebuild": "node scripts/generate-app-icons.cjs",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && vite build",
    "dist": "npm run build && electron-builder --win --publish never",
    "preview": "vite preview --host 127.0.0.1",
    "test": "node --test tests/*.test.cjs"
  },
  "build": {
    "appId": "com.reststop.app",
    "productName": "Rest Stop",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "srivatsshankar",
        "repo": "rest-stop"
      }
    ],
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/app-icon/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "Rest-Stop-${version}-windows.${ext}",
      "executableName": "Rest Stop",
      "icon": "public/app-icon/icon.ico"
    },
    "nsis": {
      "artifactName": "Rest-Stop-${version}-windows.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "include": "build/installer.nsh",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Rest Stop"
    }
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/react-fontawesome": "^3.1.1",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "cross-env": "^7.0.3",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "vite": "^8.0.16",
    "wait-on": "^8.0.1"
  },
  "devDependencies": {
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "typescript": "^5.7.2"
  }
}
